# Puerto del servidor
PORT=3001

# Credenciales de Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_public_key_here
SUPABASE_SERVICE_KEY=your_service_role_private_key_here

# URL pública del frontend (para armar links de invitación)
FRONTEND_URL=http://localhost:5173

# Proveedor de email (por ahora 'console' para solo loguear el envío)
EMAIL_PROVIDER=console

# OpenAI (requerido para chat/IA)
OPENAI_API_KEY=tu_openai_api_key
