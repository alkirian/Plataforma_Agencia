#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-push quality gates..."

# 1. Full TypeScript check (strict mode)
echo "🔧 Full TypeScript validation (strict mode)..."
npx tsc --noEmit --project tsconfig.production.json

# 2. Full ESLint check
echo "📋 Full ESLint validation..."
npm run lint

# 3. Component architecture validation
echo "🏗️  Component architecture validation..."
node scripts/detect-component-duplication.js

# 4. Full build
echo "🏗️  Full build validation..."
npm run build

# 5. Bundle size analysis
echo "📊 Bundle size analysis..."
if [ -f "dist/assets" ]; then
  echo "Bundle sizes:"
  find dist/assets -name "*.js" -exec ls -lh {} \; | awk '{print $9 ": " $5}'
fi

# 6. Security audit
echo "🔒 Security audit..."
npm audit --audit-level high

echo "✅ Pre-push validation completed!"