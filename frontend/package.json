{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "npm run quality:check && tsc && vite build",
    "build:js": "vite build",
    "build:production": "npm run quality:strict && tsc --project tsconfig.production.json && vite build --mode production",
    "type-check": "tsc --noEmit",
    "type-check:strict": "tsc --noEmit --project tsconfig.production.json",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint . --config eslint.config.js --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --config eslint.config.js --fix",
    "lint:report": "eslint . --config eslint.config.js --format html --output-file reports/eslint-report.html",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "preview": "vite preview",
    "migration:check": "tsc --noEmit --strict --skipLibCheck",
    "migration:component": "node scripts/migrate-component.js",
    "quality:check": "npm run lint && npm run type-check && npm run format:check",
    "quality:strict": "npm run lint && npm run type-check:strict && npm run format:check && npm run component:check",
    "quality:fix": "npm run lint:fix && npm run format",
    "component:check": "node scripts/detect-component-duplication.js",
    "component:analyze": "node scripts/detect-component-duplication.js --verbose",
    "component:refactor": "node scripts/refactor-duplicates.js",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "bundle:analyze": "vite build --mode analyze",
    "validate:imports": "node scripts/validate-imports.js",
    "validate:imports:fix": "node scripts/validate-imports.js --fix",
    "cleanup:console-logs": "node scripts/cleanup-console-logs.js",
    "bundle:visualize": "npx vite-bundle-analyzer dist/stats.json",
    "pre-commit": "npm run quality:check && npm run component:check",
    "prepare": "cd .. && husky install frontend/.husky",
    "postinstall": "npm run prepare"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@playwright/test": "^1.55.0",
    "@supabase/supabase-js": "^2.55.0",
    "@tanstack/react-query": "^5.85.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0",
    "vite": "^7.1.2",
    "vite-plugin-checker": "^0.8.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "tsc --noEmit --skipLibCheck"
    ]
  }
}
