# Dependencias (se pueden reinstalar)
node_modules/
/frontend/node_modules/
/backend/node_modules/

# Archivos de entorno (contienen secretos)
.env
.env.*
!.env.example
.env.local

# Archivos de Build (generados automáticamente)
/build
/dist
.next/

# Frontend build output
frontend/dist/

# Local AI/assistant caches
.claude/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*

# Archivos de Sistema Operativo
.DS_Store
Thumbs.db

# Archivos de configuración de IDEs
.idea/
.vscode/

# Archivos temporales
tmp_*
temp_*
*.tmp
*.temp
*_backup/
.temp/
*/.temp/

# Scripts temporales (excepto los en frontend/scripts/)
test-*.js
cleanup-*.js
fix-*.js

# Reportes temporales generados por scripts
*_REPORT.md
*_ANALYSIS.md
*_PLAN.md
